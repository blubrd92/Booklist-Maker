{
  "manifest_version": 3,
  "name": "Booklister Helper",
  "version": "1.0.0",
  "description": "Capture book records from BiblioCommons library catalogs and copy them as TSV for pasting into Booklister's Quick Add Spreadsheet tab.",
  "homepage_url": "https://booklister.org",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_title": "Booklister Helper",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "permissions": ["storage", "scripting", "contextMenus"],

  "host_permissions": [
    "*://*.bibliocommons.com/*",
    "*://gateway.bibliocommons.com/*",
    "*://*.syndetics.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.bibliocommons.com/v2/record/*",
        "*://*.bibliocommons.com/v2/list/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "booklister-helper@booklister.org",
      "strict_min_version": "109.0"
    }
  }
}
