{
  "manifest_version": 3,
  "name": "Booklister Helper",
  "version": "0.1.0",
  "description": "Capture book records from BiblioCommons library catalogs and copy them as TSV for pasting into Booklister's Quick Add Spreadsheet tab.",
  "homepage_url": "https://booklister.org",

  "action": {
    "default_title": "Capture this book for Booklister"
  },

  "permissions": ["storage", "scripting"],

  "host_permissions": [
    "*://*.bibliocommons.com/*",
    "*://gateway.bibliocommons.com/*",
    "*://*.syndetics.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://*.bibliocommons.com/v2/record/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  }
}
